# Laravel backend base URL. Confirm the actual port from backend/docker-compose.yml
# (nginx maps container :80 to host :8081 as of this writing) rather than assuming 8080.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1

# Never set true in a committed or production env file. Only for local preview when
# the backend container isn't running.
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=false
